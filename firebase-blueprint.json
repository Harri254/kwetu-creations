{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A digital design product available for purchase.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The name of the design." },
        "description": { "type": "string", "description": "A detailed description of the design." },
        "imageUrl": { "type": "string", "description": "URL to the preview image." },
        "psdUrl": { "type": "string", "description": "URL to the downloadable PSD file (protected)." },
        "price": { "type": "number", "description": "Price in USD." },
        "category": { "type": "string", "description": "Category of the design (e.g., Poster, Logo)." },
        "averageRating": { "type": "number", "description": "Average rating from users." },
        "reviewCount": { "type": "number", "description": "Total number of reviews." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["title", "imageUrl", "price", "category"]
    },
    "Review": {
      "title": "Review",
      "description": "A user review for a product.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the reviewer." },
        "userName": { "type": "string", "description": "Display name of the reviewer." },
        "rating": { "type": "number", "description": "Rating from 1 to 5." },
        "comment": { "type": "string", "description": "Review text." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Review timestamp." }
      },
      "required": ["userId", "rating", "comment"]
    },
    "Order": {
      "title": "Order",
      "description": "A custom design service order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the client." },
        "clientName": { "type": "string", "description": "Name of the client." },
        "designType": { "type": "string", "description": "Type of design requested." },
        "requirements": { "type": "object", "description": "Dynamic requirements based on design type." },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "cancelled"], "description": "Current status of the order." },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "paid"], "description": "Payment status." },
        "amount": { "type": "number", "description": "Total amount for the service." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Order timestamp." }
      },
      "required": ["userId", "designType", "requirements", "status", "paymentStatus"]
    },
    "Message": {
      "title": "Message",
      "description": "A message in an order chat.",
      "type": "object",
      "properties": {
        "orderId": { "type": "string", "description": "ID of the associated order." },
        "senderId": { "type": "string", "description": "UID of the sender." },
        "senderName": { "type": "string", "description": "Name of the sender." },
        "content": { "type": "string", "description": "Message text." },
        "timestamp": { "type": "string", "format": "date-time", "description": "Message timestamp." }
      },
      "required": ["orderId", "senderId", "content"]
    }
  },
  "firestore": {
    "/products": { "schema": "Product", "description": "Collection of available designs." },
    "/products/{productId}/reviews": { "schema": "Review", "description": "Sub-collection of reviews for a product." },
    "/orders": { "schema": "Order", "description": "Collection of service orders." },
    "/orders/{orderId}/messages": { "schema": "Message", "description": "Sub-collection of chat messages for an order." }
  }
}
